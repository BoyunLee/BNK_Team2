      "CMPNT_TYP_CD": "02",
      "MKPD_LTIV_ITEM_DVCD": "02",
      "MKPD_CD": "0300000161",
      "MKPD_LTIV_ITEM_NM": "상품개요",
      "MKPD_LTIV_ITEM_ATTR_CNTN": "",
      "MKPD_LTIV_ITEM_CNTN": "<p class=\"ssp-editor-p\">저소득자, 저신용자 등 금융 거래 취약층을 위한 서민금융지원 상품</p><p class=\"ssp-editor-p\">&nbsp;</p>",
