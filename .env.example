# 복사해서 사용:  cp .env.example .env  → 실제 값 채우기.  .env 는 절대 커밋하지 말 것.
# 이 값들은 도커(env_file)와 로컬(application.yml spring.config.import) 양쪽에서 주입됩니다.

# --- DB ---
DB_URL=jdbc:mysql://HOST:3306/bnk3?createDatabaseIfNotExist=true&serverTimezone=Asia/Seoul&characterEncoding=UTF-8
DB_USERNAME=root
DB_PASSWORD=

# --- 암호화 (AES-256, Base64 32바이트). 생성: openssl rand -base64 32 ---
# 주의: 운영 중 변경하면 기존에 암호화된 회원정보를 복호화할 수 없음.
CRYPTO_SECRET_KEY=

# --- 메일 (Gmail SMTP) ---
MAIL_USERNAME=
MAIL_PASSWORD=

# --- Anthropic (상품요약, 선택. 미설정 시 비활성) ---
ANTHROPIC_API_KEY=

# --- Gemini (챗봇, 미설정 시 비활성). Google AI Studio 발급 AIza... 키 ---
GEMINI_API_KEY=

# --- Qdrant ---
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# --- 도커 이미지 레지스트리(로컬빌드 푸시용, 선택) ---
# REGISTRY=yourdockerhubid
